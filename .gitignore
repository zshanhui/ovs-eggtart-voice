# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/

# Environment
.env

# Models (downloaded at runtime)
models/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Git worktrees
.worktrees/

# Wheels (binary, managed separately)
wheels/

# MTE binary weights and reference data (too large for git)
rk3576/mte/weights/
rk3576/mte/reference/

# Synced models (large files)
models/qwen3-tts/
models/qwen3-asr-v2/

# Benchmark build artifacts (deployed separately to Jetson)
benchmark/cpp/*.so
benchmark/cpp/build*/
benchmark/cpp/prebuilt/

# Local archive of process WAV/JSON outputs (not tracked)
archive/

# Local experiment scratch (calibration, v2v, results) — ignore everything
# under bench/ EXCEPT the perf harness, which is tracked.
bench/*
!bench/perf/
logs/

# Inside bench/perf/: track code + manifest, ignore generated artifacts.
bench/perf/__pycache__/
bench/perf/results/
bench/perf/corpus/short/*.wav
bench/perf/corpus/long/*.wav
bench/perf/corpus/multilingual/**/*.wav

# Internal handover / planning notes (not for repo)
docs/plans/
docs/superpowers/

# Large ASR eval datasets (download on demand)
tests/asr_real_wav_eval/dev-clean.tar.gz
tests/asr_real_wav_eval/librispeech/

# RK3576 large binaries / dumps (to be removed in seeed-voice refactor Step 4)
rk3576/engine/
rk3576/*.so
rk3576/scripts/*.wav
rk3576/scripts/*.npz
