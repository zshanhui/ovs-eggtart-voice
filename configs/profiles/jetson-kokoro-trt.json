{
  "name": "jetson-kokoro-trt",
  "description": "Jetson Orin English-only Kokoro v1.0 performance preset. Runtime uses the hand-split TensorRT encoder/decoder/source/generator path with CPU length regulator and ISTFT. No ONNX Runtime GPU/TensorRT execution providers are used.",
  "asr_backend": null,
  "tts_backend": "jetson.kokoro_trt",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "gpu"
  },
  "env": {
    "LANGUAGE_MODE": "en",
    "MODEL_DIR": "/opt/models",
    "KOKORO_MODEL_BASE": "/opt/models/kokoro-multi-lang-v1_0",
    "KOKORO_TRT_RUNTIME": "split_generator",
    "KOKORO_PERF_PROFILE": "perf",
    "KOKORO_STREAM_MAX_SEGMENT_TOKENS": "64",
    "KOKORO_SYNTH_MAX_SEGMENT_TOKENS": "64",
    "KOKORO_STREAM_CHUNK_MS": "40",
    "KOKORO_SPLIT_ENCODER_ENGINE": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_prefix_encoder_dyn4_128_fp16.engine",
    "KOKORO_SPLIT_LENGTH_ONNX": "/opt/models/kokoro-multi-lang-v1_0/engines/cpu_length_regulator.onnx",
    "KOKORO_SPLIT_DECODER_ENGINE": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_decoder_backbone_dyn64_256_fp16.engine",
    "KOKORO_SPLIT_DECODER_ENGINE_LONG": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_decoder_backbone_dyn256_512_fp16.engine",
    "KOKORO_SPLIT_SOURCE_ENGINE": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_source_dyn128_512_bf16.engine",
    "KOKORO_SPLIT_SOURCE_ENGINE_LONG": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_source_dyn512_1024_bf16.engine",
    "KOKORO_SPLIT_GENERATOR_ENGINE": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_rest_preexp_dyn64_256_fp16.engine",
    "KOKORO_SPLIT_GENERATOR_ENGINE_LONG": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_rest_preexp_dyn256_512_fp16.engine",
    "KOKORO_SPLIT_ISTFT_ONNX": "/opt/models/kokoro-multi-lang-v1_0/engines/cpu_postspec_istft.onnx",
    "KOKORO_DEFAULT_SID": "52",
    "TTS_DEFAULT_SID": "52"
  },
  "required_engines": [
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_prefix_encoder_dyn4_128_fp16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_prefix_encoder_dyn4_128_fp16.engine",
      "env_var": "KOKORO_SPLIT_ENCODER_ENGINE",
      "onnx_input": "engines/kokoro_prefix_encoder.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_prefix_encoder_dyn4_128_fp16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "extra_files": [
        "engines/cpu_length_regulator.onnx",
        "engines/cpu_generator_source.onnx",
        "engines/cpu_postspec_istft.onnx"
      ],
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_decoder_backbone_dyn64_256_fp16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_decoder_backbone_dyn64_256_fp16.engine",
      "env_var": "KOKORO_SPLIT_DECODER_ENGINE",
      "onnx_input": "engines/decoder_backbone_prefix.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_decoder_backbone_dyn64_256_fp16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_decoder_backbone_dyn256_512_fp16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_decoder_backbone_dyn256_512_fp16.engine",
      "env_var": "KOKORO_SPLIT_DECODER_ENGINE_LONG",
      "onnx_input": "engines/decoder_backbone_prefix.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_decoder_backbone_dyn256_512_fp16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_generator_source_dyn128_512_bf16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_source_dyn128_512_bf16.engine",
      "env_var": "KOKORO_SPLIT_SOURCE_ENGINE",
      "onnx_input": "engines/cpu_generator_source.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_generator_source_dyn128_512_bf16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_generator_source_dyn512_1024_bf16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_source_dyn512_1024_bf16.engine",
      "env_var": "KOKORO_SPLIT_SOURCE_ENGINE_LONG",
      "onnx_input": "engines/cpu_generator_source.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_generator_source_dyn512_1024_bf16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_generator_rest_preexp_dyn64_256_fp16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_rest_preexp_dyn64_256_fp16.engine",
      "env_var": "KOKORO_SPLIT_GENERATOR_ENGINE",
      "onnx_input": "engines/generator_rest_preexp.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_generator_rest_preexp_dyn64_256_fp16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "kokoro-multi-lang-v1_0",
      "engine_file": "kokoro_generator_rest_preexp_dyn256_512_fp16.engine",
      "engine_path": "/opt/models/kokoro-multi-lang-v1_0/engines/kokoro_generator_rest_preexp_dyn256_512_fp16.engine",
      "env_var": "KOKORO_SPLIT_GENERATOR_ENGINE_LONG",
      "onnx_input": "engines/generator_rest_preexp.onnx",
      "build_script": "scripts/build_kokoro_split_generator_trt.sh",
      "build_env": {
        "ENGINE_NAME": "kokoro_generator_rest_preexp_dyn256_512_fp16.engine",
        "MODEL_DIR": "/opt/models/kokoro-multi-lang-v1_0",
        "OUT_DIR": "/opt/models/kokoro-multi-lang-v1_0/engines"
      },
      "hf_only": false,
      "required": true
    }
  ],
  "tts_model_id": "kokoro-multi-lang-v1_0"
}
