{
  "name": "jetson-moss-tts-nano",
  "description": "MOSS-TTS-Nano 0.1B TTS backend (ORT Python subprocess fallback path) for Jetson Orin. 48kHz stereo, SentencePiece tokenizer, ONNX bundle. ORT CPU EP TTFA ~3000ms. Use jetson-moss-tts-nano-trt (C++ TRT path, TTFA ~157ms) as the default; this profile is the deterministic CPU-only fallback when the C++ binary is unavailable or its dependencies (CUDA/TRT) are missing.",
  "asr_backend": null,
  "tts_backend": "jetson.moss_tts_nano",
  "tts_model_id": "moss-tts-nano-v1",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "gpu"
  },
  "env": {
    "LANGUAGE_MODE": "multilanguage",
    "TTS_BACKEND": "moss_tts_nano",
    "OVS_VAD_BACKEND": "silero",
    "OVS_VAD_SILENCE_MS": "400",

    "MOSS_WORKER_BIN": "/opt/jv-workers/moss_tts_nano_ort_worker.py",
    "MOSS_PY_REPO": "/opt/moss-tts-nano-py",
    "MOSS_ENGINE_DIR": "/opt/models/moss-tts-nano/onnx-bundle",
    "MOSS_TOKENIZER": "/opt/models/moss-tts-nano/onnx-bundle/MOSS-TTS-Nano-100M-ONNX/tokenizer.model",
    "MOSS_CODEC_ONNX_DIR": "/opt/models/moss-tts-nano/onnx-bundle/MOSS-Audio-Tokenizer-Nano-ONNX",
    "MOSS_ORT_EP": "cpu",
    "MOSS_ORT_THREADS": "4",
    "MOSS_MAX_SLOTS": "1",
    "MOSS_MAX_SEQ_LEN": "1024",

    "OVS_TTS_SAMPLE_RATE": "48000",
    "OVS_TTS_CHANNELS": "2",
    "OVS_TTS_SEED": "42"
  },
  "moss_max_slots": 1,
  "moss_max_seq_len": 1024,
  "moss_sample_rate": 48000,
  "moss_channels": 2,
  "required_engines": [
    {
      "model_id": "moss-tts-nano",
      "engine_file": "moss_tts_prefill.plan",
      "engine_path": "/opt/models/moss-tts-nano/engines/moss_tts_prefill.plan",
      "env_var": "MOSS_ENGINE_DIR",
      "onnx_input": "moss_tts_prefill.onnx",
      "build_script": "scripts/build_moss_tts_engines.sh",
      "build_env": {
        "ENGINE_NAME": "moss_tts_prefill.plan",
        "ONNX_DIR": "/opt/models/moss-tts-nano/onnx",
        "OUT_DIR": "/opt/models/moss-tts-nano/engines",
        "MIN_SEQ": "1",
        "OPT_SEQ": "32",
        "MAX_SEQ": "256"
      },
      "extra_files": [
        "tts_browser_onnx_meta.json",
        "browser_poc_manifest.json",
        "tokenizer.model",
        "moss_tts_global_shared.data",
        "moss_tts_local_shared.data"
      ],
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "moss-tts-nano",
      "engine_file": "moss_tts_decode_step.plan",
      "engine_path": "/opt/models/moss-tts-nano/engines/moss_tts_decode_step.plan",
      "env_var": "MOSS_ENGINE_DIR",
      "onnx_input": "moss_tts_decode_step.onnx",
      "build_script": "scripts/build_moss_tts_engines.sh",
      "build_env": {
        "ENGINE_NAME": "moss_tts_decode_step.plan",
        "MIN_PAST": "1",
        "OPT_PAST": "64",
        "MAX_PAST": "512"
      },
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "moss-tts-nano",
      "engine_file": "moss_tts_local_decoder.plan",
      "engine_path": "/opt/models/moss-tts-nano/engines/moss_tts_local_decoder.plan",
      "env_var": "MOSS_ENGINE_DIR",
      "onnx_input": "moss_tts_local_decoder.onnx",
      "build_script": "scripts/build_moss_tts_engines.sh",
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "moss-tts-nano",
      "engine_file": "moss_tts_local_cached_step.plan",
      "engine_path": "/opt/models/moss-tts-nano/engines/moss_tts_local_cached_step.plan",
      "env_var": "MOSS_ENGINE_DIR",
      "onnx_input": "moss_tts_local_cached_step.onnx",
      "build_script": "scripts/build_moss_tts_engines.sh",
      "hf_only": false,
      "required": false
    },
    {
      "model_id": "moss-tts-nano",
      "engine_file": "moss_tts_local_fixed_sampled_frame.plan",
      "engine_path": "/opt/models/moss-tts-nano/engines/moss_tts_local_fixed_sampled_frame.plan",
      "env_var": "MOSS_ENGINE_DIR",
      "onnx_input": "moss_tts_local_fixed_sampled_frame.onnx",
      "build_script": "scripts/build_moss_tts_engines.sh",
      "hf_only": false,
      "required": true
    },
    {
      "model_id": "moss-audio-tokenizer-nano",
      "engine_file": "codec_decode_step.plan",
      "engine_path": "/opt/models/moss-tts-nano/codec_onnx/codec_decode_step.plan",
      "env_var": "MOSS_CODEC_ONNX_DIR",
      "onnx_input": "moss_audio_tokenizer_decode_step.onnx",
      "build_script": "scripts/build_moss_tts_engines.sh",
      "build_env": {
        "ENGINE_NAME": "codec_decode_step.plan",
        "MIN_FRAMES": "1",
        "OPT_FRAMES": "4",
        "MAX_FRAMES": "8"
      },
      "extra_files": [
        "codec_browser_onnx_meta.json",
        "moss_audio_tokenizer_encode.onnx",
        "moss_audio_tokenizer_decode_shared.data"
      ],
      "hf_only": false,
      "required": true
    }
  ],
  "artifact_set": "orin-nx-moss-tts-nano-2026-05-23",
  "speaker_tables": {
    "default": ""
  }
}
