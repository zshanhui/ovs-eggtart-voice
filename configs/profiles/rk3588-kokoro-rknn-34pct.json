{
  "name": "rk3588-kokoro-rknn-34pct",
  "description": "RK3588 multilingual TTS via Kokoro 4-stage hybrid (CPU prefix ONNX + RKNN decoder-front INT8 + RKNN vocoder-front-half FP16 + CPU tail-rest ONNX). Increases NPU share from ~17% (3-stage) to ~34% by offloading the front half of the vocoder to NPU. Paired with Qwen3 ASR (RKNN encoder + RKLLM decoder fp16).",
  "asr_backend": "rk.asr",
  "tts_backend": "rk.tts",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "npu"
  },
  "env": {
    "LANGUAGE_MODE": "rk",
    "RK_PLATFORM": "rk3588",
    "ASR_BACKEND": "qwen3_asr_rk",
    "OVS_VAD_BACKEND": "silero",
    "OVS_VAD_SILENCE_MS": "400",
    "ASR_DECODER_TYPE": "rkllm",
    "ASR_PLATFORM": "rk3588",
    "ASR_DECODER_QUANT": "fp16",
    "ASR_NPU_CORE_MASK": "NPU_CORE_AUTO",
    "ASR_ENABLED_CPUS": "4",
    "ASR_MODEL_DIR": "/opt/asr/models",
    "RKLLM_LIB_PATH": "/opt/asr/lib/librkllmrt.so",
    "QWEN3_ASR_CHUNK_CONFIRM": "0",
    "QWEN3_ASR_STREAM_TRUE": "1",
    "MODEL_DIR": "/opt/kokoro-rknn",
    "RK_ARTIFACT_SET": "rk3588-kokoro-hybrid-34pct-2026-05-23",
    "TTS_BACKEND": "kokoro_rknn",
    "KOKORO_MODEL_DIR": "/opt/kokoro-rknn",
    "KOKORO_RKNN_MODE": "hybrid",
    "KOKORO_PREFIX_ONNX": "kokoro-prefix-cpu.onnx",
    "KOKORO_FRONT_RKNN": "rk3588/kokoro-decoder-front.int8.rknn",
    "KOKORO_TAIL_ONNX": "kokoro-generator-tail-cpu.onnx",
    "KOKORO_RKNN_VOCODER_FRONT_PATH": "rk3588/kokoro-vocoder-front-half.native.fp16.rknn",
    "KOKORO_RKNN_TAIL_REST_PATH": "kokoro-vocoder-tail-rest-cpu.onnx",
    "KOKORO_SEQ_LEN": "32",
    "KOKORO_SAMPLE_RATE": "24000",
    "KOKORO_VOICE": "default",
    "KOKORO_PREFIX_ORT_INTRA_OP": "1",
    "KOKORO_PREFIX_ORT_INTER_OP": "1",
    "KOKORO_TAIL_ORT_INTRA_OP": "4",
    "KOKORO_TAIL_ORT_INTER_OP": "1",
    "KOKORO_ORT_GRAPH_OPT": "all",
    "KOKORO_ORT_ENABLE_MEM_PATTERN": "0"
  },
  "tts_model_id": "kokoro-multi-lang-v1_0"
}
