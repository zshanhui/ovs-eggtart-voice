{
  "name": "rk3588-paraformer-matcha",
  "description": "Rockchip RK3588 Paraformer + Matcha: Paraformer RKNN ASR (hybrid NPU encoder + ONNX CPU decoder) with Matcha RKNN TTS. Validated NPU core partitioning (Paraformer encoder NPU_CORE_1_2, Matcha NPU_CORE_0).",
  "asr_backend": "rk.asr",
  "tts_backend": "rk.tts",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "npu"
  },
  "env": {
    "LANGUAGE_MODE": "rk",
    "RK_PLATFORM": "rk3588",
    "ASR_BACKEND": "paraformer_rknn",
    "PARAFORMER_MODEL_DIR": "/opt/asr/paraformer",
    "PARAFORMER_RKNN_DIR": "/opt/asr/paraformer/rknn/rk3588",
    "PARAFORMER_RKNN_ENC_PRECISION": "fp16",
    "PARAFORMER_RKNN_ENCODER_MODE": "hybrid",
    "PARAFORMER_RKNN_DECODER": "cpu",
    "PARAFORMER_ENCODER_SUFFIX_ONNX": "/opt/asr/paraformer/encoder_suffix_from_block30.onnx",
    "PARAFORMER_DECODER_ONNX": "/opt/asr/paraformer/decoder-rknn.onnx",
    "PARAFORMER_RKNN_ENC_CORE": "NPU_CORE_1_2",
    "PARAFORMER_PREROLL_MS": "100",
    "TTS_MODEL_DIR": "/opt/tts/models",
    "TTS_BACKEND": "matcha_rknn",
    "SHERPA_TTS_MODEL_DIR": "/opt/tts/models/matcha-icefall-zh-en",
    "TTS_PROVIDER": "cpu",
    "TTS_NUM_THREADS": "4",
    "TTS_DEFAULT_SID": "0",
    "MODEL_DIR": "/opt/tts/models",
    "MATCHA_USE_ORT": "1",
    "MATCHA_MODEL": "matcha-s64.rknn",
    "MATCHA_MAX_PHONEMES": "64",
    "MATCHA_MODEL_SEQ_LEN": "80",
    "VOCOS_MODEL": "vocos-16khz-600.rknn",
    "VOCOS_FRAMES": "256"
  },
  "tts_model_id": "matcha-icefall-zh-en.rknn"
}
