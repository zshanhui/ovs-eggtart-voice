# syntax=docker/dockerfile:1.6
#
# OpenVoiceStream — Jetson Orin Nano / NX / AGX (JetPack 6.x, CUDA 12.6, TRT 10.3)
#
# Single Python dependency set, selected at runtime by profile:
#   jetson-zh-en                 — Paraformer ASR + Matcha TTS (zh_en default)
#   jetson-qwen3asr-matcha-nx    — Qwen3 ASR + Matcha TTS (multilanguage default,
#                                  runs on Nano 8GB and NX 16GB)
#   jetson-multilang-highperf    — Qwen3 ASR + Qwen3 TTS heavy preset (NX/AGX only)
#
# Build:
#   docker build -f deploy/docker/Dockerfile.jetson \
#                --build-arg LANGUAGE_MODE=zh_en \
#                -t openvoicestream:jetson-zh_en .
#
# Runtime (GPU access requires --runtime=nvidia):
#   docker run --runtime=nvidia --network=host \
#     -e OVS_PROFILE=jetson-zh-en \
#     -v seeed-models:/opt/models \
#     openvoicestream:jetson-zh_en

ARG LANGUAGE_MODE=zh_en

# ---------------------------------------------------------------------------
# Base: Ubuntu 22.04 ARM64 — CUDA/TRT libs mounted from Jetson host at runtime
# ---------------------------------------------------------------------------
FROM arm64v8/ubuntu:22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# Build-time PyPI mirror
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX}

# System deps + Python 3.10
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.10 python3.10-dev python3-pip \
        libasound2 libsndfile1 sox curl ca-certificates binutils \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1 \
    && rm -rf /var/lib/apt/lists/*

# FastAPI + runtime deps (shared by both modes)
RUN pip3 install --no-cache-dir --index-url ${PIP_INDEX} \
        fastapi \
        "uvicorn[standard]" \
        soundfile \
        python-multipart \
        numpy \
        tokenizers \
        "transformers<5" \
        "webrtcvad-wheels>=2.0.14" \
        "cuda-python>=12,<13" \
        websockets \
        requests \
        "pysbd>=0.3.4" \
        "onnxruntime>=1.20" \
        "onnx>=1.16" \
        piper-phonemize

# ----------------------------------------------------------------------------
# Final stage: single FROM with LANGUAGE_MODE-conditional RUN
# ----------------------------------------------------------------------------
FROM base AS final

ARG LANGUAGE_MODE=zh_en
ENV LANGUAGE_MODE=${LANGUAGE_MODE}

RUN set -eux; \
    case "$LANGUAGE_MODE" in \
      zh_en) echo "OVS_PROFILE_DEFAULT=jetson-zh-en" >> /etc/openvoicestream.env ;; \
      multilanguage) echo "OVS_PROFILE_DEFAULT=jetson-qwen3asr-matcha-nx" >> /etc/openvoicestream.env ;; \
      *) echo "Unknown LANGUAGE_MODE=$LANGUAGE_MODE (expected zh_en|multilanguage)" >&2; exit 1 ;; \
    esac; \
    rm -rf /root/.cache /tmp/*

# Application code
COPY app/      /opt/speech/app/
COPY configs/  /opt/speech/configs/
COPY voices/   /opt/speech/voices/
COPY scripts/  /opt/speech/scripts/
COPY deploy/docker/entrypoint.jetson.sh /opt/speech/entrypoint.jetson.sh
RUN chmod +x /opt/speech/entrypoint.jetson.sh

# Qwen3 high-performance runtime bundle. This is intentionally separate from
# model/engine artifacts: qwen3-edgellm owns artifact manifest/download/verify,
# while the image owns the runtime worker/plugin binaries and validation scripts.
COPY deploy/jetson-workers/ /opt/jv-workers/
COPY third_party/qwen3-edgellm-jetson/ /opt/qwen3-edgellm-jetson/

# Models are downloaded on first start by app/core/model_downloader.py based on
# LANGUAGE_MODE / OVS_PROFILE. Cached in /opt/models volume.
RUN set -eux; \
    mkdir -p /opt/models /opt/edgellm /opt/edgellm-bin /opt/models/qwen3-edgellm; \
    chmod +x /opt/jv-workers/qwen3_asr_worker /opt/jv-workers/qwen3_tts_worker; \
    if [ -f /opt/jv-workers/moss_tts_nano_worker ]; then chmod +x /opt/jv-workers/moss_tts_nano_worker; fi; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin.so /opt/edgellm/libNvInfer_edgellm_plugin.so; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin_asr.so /opt/edgellm/libNvInfer_edgellm_plugin_asr.so; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin.so /opt/edgellm-bin/libNvInfer_edgellm_plugin.so; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin_asr.so /opt/edgellm-bin/libNvInfer_edgellm_plugin_asr.so

ENV MODEL_DIR=/opt/models \
    NVIDIA_VISIBLE_DEVICES=all \
    CUDA_MODULE_LOADING=LAZY \
    EDGE_LLM_BASE=/opt/edgellm-bin \
    EDGE_LLM_BUILD_DIR=. \
    OVS_WORKER_BUILD=/opt/jv-workers \
    QWEN3_EDGELLM_JETSON_ROOT=/opt/qwen3-edgellm-jetson \
    EDGELLM_PLUGIN_PATH=/opt/edgellm-bin/libNvInfer_edgellm_plugin.so \
    LD_LIBRARY_PATH=/usr/local/lib/python3.10/dist-packages/onnxruntime/capi:/host-cuda:/host-nvidia-libs:/host-libs \
    PYTHONPATH=/opt/speech:/usr/lib/python3.10/dist-packages

LABEL org.opencontainers.image.title="OpenVoiceStream" \
      org.opencontainers.image.source="https://github.com/suharvest/openvoicestream" \
      org.opencontainers.image.description="GPU-accelerated speech service for Jetson Orin"

WORKDIR /opt/speech
EXPOSE 8000

ENTRYPOINT ["/opt/speech/entrypoint.jetson.sh"]
CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
