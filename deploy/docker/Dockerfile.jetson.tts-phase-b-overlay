# TTS Phase B + sentence pipeline parallelism overlay.
#
# Base: production jetson-v1.14-hotswap image (untouched runtime stack).
# This overlay only swaps the 4 files that changed for Phase B work,
# keeping pip/system layers cached. Build cost: ~30s vs ~30min for a
# full rebuild.
#
# Build:
#   docker build -f deploy/docker/Dockerfile.jetson.tts-phase-b-overlay \
#                -t openvoicestream:jetson-v1.15-tts-phase-b .
#
# What's overlaid:
#   /opt/jv-workers/qwen3_tts_worker
#       Phase B Option B build (fork commit 8a286ce)
#       md5 4cf47793532b3951ffa5c77585b0eae4
#       sha256 a5ed07ceb5d7e6086aaf314f37e7b85026111f781de42ec5d167ffbed488fc94
#
#   /opt/speech/app/main.py
#       Part D disconnect watcher (fe2ba23)
#       OVS_TTS_STREAM_MAX_WORKERS env knob (0fb752e, 8d6d1b2)
#       Sentence pipeline parallelism (e67bd37)
#
#   /opt/speech/app/backends/jetson/trt_edge_llm_tts.py
#       _WorkerIO cancel counter for Part D telemetry
#
#   /opt/speech/configs/profiles/jetson-multilang-highperf-nx.json
#       OVS_TTS_WORKER_CONCURRENCY=2 wired through to TTS worker subprocess

ARG BASE_IMAGE=sensecraft-missionpack.seeed.cn/solution/seeed-local-voice:jetson-v1.14-hotswap

FROM ${BASE_IMAGE}

# Phase B TTS worker binary (per-slot tensor pool, cancel protocol, etc.)
COPY deploy/jetson-workers/qwen3_tts_worker /opt/jv-workers/qwen3_tts_worker

# Python: Part D disconnect watcher + pipeline parallelism + env knob
COPY app/main.py /opt/speech/app/main.py
COPY app/backends/jetson/trt_edge_llm_tts.py /opt/speech/app/backends/jetson/trt_edge_llm_tts.py

# Profile: OVS_TTS_WORKER_CONCURRENCY=2 wired through
COPY configs/profiles/jetson-multilang-highperf-nx.json /opt/speech/configs/profiles/jetson-multilang-highperf-nx.json

# Sanity: ensure the worker binary is still executable after COPY
RUN chmod +x /opt/jv-workers/qwen3_tts_worker \
    && test -x /opt/jv-workers/qwen3_tts_worker \
    && md5sum /opt/jv-workers/qwen3_tts_worker
